{
	"appId": "app.memora.ios",
	"appName": "Mimora",
	"server": {
		"url": "https://memora-app-one.vercel.app",
		"cleartext": false
	},
	"ios": {
		"contentInset": "never",
		"scrollEnabled": false,
		"backgroundColor": "#FFFFFF"
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"launchAutoHide": true,
			"backgroundColor": "#FFFFFF",
			"showSpinner": false,
			"splashFullScreen": true,
			"splashImmersive": true
		}
	},
	"packageClassList": []
}
